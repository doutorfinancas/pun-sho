API_PORT=8080
UNKNOWN_PAGE=https://www.google.com/search?q=this+is+a+404
HOST_NAME=http://localhost:8080/
AUTH_TOKEN=ThisIsA5uper$ecureAPIToken
DB_USERNAME=your-user
DB_PASSWORD=your-pun-chword
DB_NAME=pun_sho
DB_URL=something-somewhere-over-the-rainbow
DB_PORT=26257
DB_ADAPTOR=cockroach
QR_PNG_LOGO=./img/logo_df.png
SSL_MODE=full-verify
PUBLIC_ID_LENGTH=7
# Social media bots allowed to access shortlinks for previews (comma-separated)
# Leave empty to block all bots, or specify only the ones you want to allow
# Example: ALLOWED_SOCIAL_BOTS=facebookexternalhit,googlebot,linkedinbot
ALLOWED_SOCIAL_BOTS=

# Auth & Session
ADMIN_DEFAULT_PASSWORD=changeme123
COOKIE_DOMAIN=localhost
SESSION_DURATION=48h

# Microsoft OAuth (optional — MS login button hidden if empty)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_SECRET=
# Comma-separated Azure AD group IDs to restrict MS login (optional)
MICROSOFT_ALLOWED_GROUPS=

# GeoIP (optional — geo lookups disabled if missing)
# Auto-downloads from MaxMind on first start if license key is set and DB file is missing
# Get a free license key at https://www.maxmind.com/en/geolite2/signup
GEOIP_DB_PATH=./GeoLite2-City.mmdb
GEOIP_LICENSE_KEY=
